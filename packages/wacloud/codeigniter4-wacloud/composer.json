{
    "name": "wacloud/codeigniter4-wacloud",
    "description": "CodeIgniter 4 package untuk integrasi WACloud WhatsApp Gateway API",
    "keywords": [
        "wacloud",
        "whatsapp",
        "whatsapp-api",
        "whatsapp-gateway",
        "codeigniter",
        "codeigniter4",
        "ci4",
        "messaging",
        "notification",
        "whatsapp-sdk",
        "php"
    ],
    "type": "library",
    "license": "MIT",
    "homepage": "https://wacloud.id",
    "support": {
        "issues": "https://github.com/wacloud/codeigniter4-wacloud/issues",
        "source": "https://github.com/wacloud/codeigniter4-wacloud",
        "docs": "https://wacloud.id/docs.html",
        "email": "support@wacloud.id"
    },
    "authors": [
        {
            "name": "WACloud",
            "email": "support@wacloud.id",
            "homepage": "https://wacloud.id",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.3|^4.4|^4.5",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0"
    },
    "autoload": {
        "psr-4": {
            "WACloud\\CodeIgniter4WACloud\\": "src/",
            "Config\\": "src/Config/"
        },
        "files": [
            "src/Helpers/wacloud_helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "WACloud\\CodeIgniter4WACloud\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    }
}

